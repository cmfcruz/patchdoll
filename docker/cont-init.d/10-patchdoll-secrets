#!/usr/bin/env bash
set -eu

# shellcheck source=../s6/scripts/lib.sh
. /etc/s6-overlay/scripts/lib.sh

# Move selected secret environment variables into a root-owned file before
# supervised services start. This reduces accidental exposure to child processes
# through normal environment inheritance, but it does not hide secrets from the
# container runtime, Docker metadata, root users, or processes with access to
# /run/secrets/patchdoll.env when that path is writable, or /run/patchdoll/secrets.env
# when /run/secrets is a read-only Docker secrets mount.

umask 077

SECRET_ENV_VARS="
CLAUDE_CODE_OAUTH_TOKEN
ANTHROPIC_API_KEY
PATCHDOLL_SLACK_APP_TOKEN
PATCHDOLL_SLACK_BOT_TOKEN
PATCHDOLL_GITHUB_APP_ID
PATCHDOLL_GITHUB_APP_INSTALLATION_ID
PATCHDOLL_GITHUB_APP_PRIVATE_KEY_BASE64
PATCHDOLL_NGROK_AUTHTOKEN
PATCHDOLL_GITHUB_WEBHOOK_SECRET
CODEX_ACCESS_TOKEN
OPENAI_API_KEY
"

preferred_secrets_dir="/run/secrets"
fallback_secrets_dir="/run/patchdoll"
preferred_secrets_file="${preferred_secrets_dir}/patchdoll.env"
fallback_secrets_file="${fallback_secrets_dir}/secrets.env"
s6_env_dirs="/var/run/s6/container_environment /run/s6/container_environment"
written=0

write_secret() {
  local name="$1"
  local value="$2"
  local output_file="$3"

  printf '%s=' "$name" >> "$output_file"
  shell_quote "$value" >> "$output_file"
  printf '\n' >> "$output_file"
}

secrets_dir="$preferred_secrets_dir"
secrets_file="$preferred_secrets_file"
mkdir -p "$preferred_secrets_dir" 2>/dev/null || true

# /run/secrets is often a read-only Docker secrets mount. Prefer it for
# consistency when writable, but fall back to /run/patchdoll so env-file based
# secrets still get scrubbed before services start.
if tmp_file="$(mktemp "${preferred_secrets_file}.XXXXXX" 2>/dev/null)"; then
  :
else
  secrets_dir="$fallback_secrets_dir"
  secrets_file="$fallback_secrets_file"
  mkdir -p "$secrets_dir"
  tmp_file="$(mktemp "${secrets_file}.XXXXXX")"
fi
chmod 0600 "$tmp_file"

# Preserve existing entries when the selected secrets file already exists.
# New env-derived assignments are appended below, so the usual "last value wins"
# env-file behavior still lets runtime env override older entries.
if [ -r "$secrets_file" ]; then
  cat "$secrets_file" > "$tmp_file"
fi

for name in $SECRET_ENV_VARS; do
  case "$name" in
    [A-Za-z_][A-Za-z0-9_]*) ;;
    *)
      echo "patchdoll-secrets: invalid secret environment variable name: ${name}" >&2
      rm -f "$tmp_file"
      exit 1
      ;;
  esac

  if [ -v "$name" ]; then
    write_secret "$name" "${!name}" "$tmp_file"
    written=1
    for s6_env_dir in $s6_env_dirs; do
      rm -f "${s6_env_dir}/${name}"
    done
    unset "$name"
  fi
done

if [ "$written" -eq 1 ]; then
  mv "$tmp_file" "$secrets_file"
  # Allow the patchdoll-group server process to read secrets (e.g. to mint
  # GitHub App tokens) while keeping them hidden from the codex/claude worker
  # users, which are not members of the patchdoll group. This mirrors the
  # group-readable secrets the elma-secrets sidecar produces.
  chown root:patchdoll "$secrets_file" 2>/dev/null || true
  chmod 0640 "$secrets_file"
else
  rm -f "$tmp_file"
fi
