#!/usr/bin/env bash
set -eu

# shellcheck source=../s6/scripts/lib.sh
. /etc/s6-overlay/scripts/lib.sh

# Move selected secret environment variables into a root-owned file before
# supervised services start. This reduces accidental exposure to child processes
# through normal environment inheritance, but it does not hide secrets from the
# container runtime, Docker metadata, root users, or root-readable runtime files.

umask 077

SECRET_ENV_VARS="
CLAUDE_CODE_OAUTH_TOKEN
ANTHROPIC_API_KEY
PATCHDOLL_SLACK_APP_TOKEN
PATCHDOLL_SLACK_BOT_TOKEN
PATCHDOLL_GITHUB_APP_ID
PATCHDOLL_GITHUB_APP_INSTALLATION_ID
PATCHDOLL_GITHUB_APP_PRIVATE_KEY_BASE64
PATCHDOLL_NGROK_AUTHTOKEN
PATCHDOLL_GITHUB_WEBHOOK_SECRET
CODEX_ACCESS_TOKEN
OPENAI_API_KEY
"

secrets_dir="/run/secrets"
secrets_file="${secrets_dir}/patchdoll.env"
s6_env_dirs="/var/run/s6/container_environment /run/s6/container_environment"
written=0
tmp_file=""

write_secret() {
  local name="$1"
  local value="$2"
  local output_file="$3"

  {
    printf '%s=' "$name"
    shell_quote "$value"
    printf '\n'
  } >> "$output_file"
}

mkdir -p "$secrets_dir" 2>/dev/null || true

# Env-derived secrets are a snapshot of the current container environment, not
# a merge with a previous secrets file. If /run/secrets is a read-only mount,
# env-derived secrets cannot be migrated.
if tmp_file="$(mktemp "${secrets_file}.XXXXXX" 2>/dev/null)"; then
  chmod 0600 "$tmp_file"
  : > "$tmp_file"
else
  tmp_file=""
fi

for name in $SECRET_ENV_VARS; do
  case "$name" in
    [A-Za-z_][A-Za-z0-9_]*) ;;
    *)
      echo "patchdoll-secrets: invalid secret environment variable name: ${name}" >&2
      rm -f "$tmp_file"
      exit 1
      ;;
  esac

  secret_present=0
  secret_value=""
  if [ -v "$name" ]; then
    secret_present=1
    secret_value="${!name}"
  else
    for s6_env_dir in $s6_env_dirs; do
      if [ -f "${s6_env_dir}/${name}" ]; then
        secret_present=1
        secret_value="$(cat "${s6_env_dir}/${name}")"
        break
      fi
    done
  fi

  if [ "$secret_present" -eq 1 ]; then
    if [ -z "$tmp_file" ]; then
      echo "patchdoll-secrets: cannot migrate ${name}; ${secrets_file} is not writable" \
        >&2
      exit 1
    fi
    write_secret "$name" "$secret_value" "$tmp_file"
    written=1
    for s6_env_dir in $s6_env_dirs; do
      rm -f "${s6_env_dir}/${name}"
    done
    unset "$name"
  fi
done

ensure_patchdoll_readable() {
  local file="$1"

  [ -f "$file" ] || return 0
  chown root:patchdoll "$file" 2>/dev/null || true
  chmod 0640 "$file" 2>/dev/null || true
  if s6-setuidgid patchdoll test -r "$file"; then
    return 0
  fi

  echo "patchdoll-secrets: ${file} must be readable by the patchdoll user" >&2
  exit 1
}

# Allow the patchdoll-group server process to read secrets (e.g. Slack tokens
# and GitHub App credentials) while keeping them hidden from the agent worker
# user, which is not a member of the patchdoll group.
if [ "$written" -eq 1 ]; then
  mv "$tmp_file" "$secrets_file"
  ensure_patchdoll_readable "$secrets_file"
elif [ -n "$tmp_file" ]; then
  rm -f "$tmp_file"
  rm -f "$secrets_file" 2>/dev/null || {
    echo "patchdoll-secrets: could not remove stale ${secrets_file}" >&2
    exit 1
  }
else
  rm -f "$secrets_file" 2>/dev/null || {
    echo "patchdoll-secrets: could not remove stale ${secrets_file}" >&2
    exit 1
  }
fi
