{
  "name": "patchdoll-monorepo",
  "version": "1.0.0",
  "private": true,
  "description": "Event-triggered wrapper around AI CLI tools with adapter-mediated external actions.",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "tsc -b",
    "start": "node packages/core/dist/server.js",
    "check": "tsc -b",
    "test": "tsc -b && node --test \"packages/*/test/*.test.ts\"",
    "patchdoll:build": "docker build -t patchdoll:latest .",
    "patchdoll:stop": "docker stop --timeout 15 patchdoll",
    "prepare": "husky",
    "lint": "npm run lint:eslint && npm run lint:shell && npm run lint:docker && npm run lint:yaml",
    "lint:eslint": "eslint . --max-warnings=0",
    "lint:shell": "tools/lint-shell.sh",
    "lint:docker": "tools/lint-dockerfiles.sh",
    "lint:yaml": "tools/lint-yaml.sh",
    "lint:staged": "lint-staged"
  },
  "engines": {
    "node": ">=24"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "25.9.2",
    "eslint": "^10.4.1",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "typescript": "6.0.3",
    "typescript-eslint": "^8.61.0"
  },
  "lint-staged": {
    "*.{js,cjs,mjs,ts}": "eslint --max-warnings=0",
    "*.{sh,bash}": "tools/lint-shell.sh",
    "docker/cont-init.d/*": "tools/lint-shell.sh",
    "docker/s6/s6-rc.d/**/{run,up,*.sh}": "tools/lint-shell.sh",
    "docker/s6/scripts/*": "tools/lint-shell.sh",
    "Dockerfile*": "tools/lint-dockerfiles.sh",
    "*.{yml,yaml}": "tools/lint-yaml.sh"
  }
}
